{
	"version": 8,
	"configurePresets" : [
		{
			"name": "default",
			"displayName": "Default generator",
			"binaryDir": "${sourceDir}/build"
		}, 
		{

			"name": "ninja-multi",
			"displayName": "Ninja Multi-Config generator",
			"generator": "Ninja Multi-Config",
			"binaryDir": "${sourceDir}/build"
		}
	],
	"buildPresets" : [
		{
			"name": "debug",
			"configurePreset": "default",
			"configuration": "Debug"
		},
		{
			"name": "release",
			"configurePreset": "default",
			"configuration": "Release"
		},
		{ 
			"name": "ninja-multi-debug",
			"configurePreset": "ninja-multi",
			"configuration": "Debug"
		},
		{
			"name": "ninja-multi-release",
			"configurePreset": "ninja-multi",
			"configuration": "Release"
		}
	] ,
	"workflowPresets": [
		{
			"name": "default-debug",
			"steps": [
				{
					"type": "configure",
					"name": "default"
				},
				{
					"type": "build",
					"name": "debug"
				}
			]
		} ,
		{
			"name": "default-release",
			"steps": [
				{
					"type": "configure",
					"name": "default"
				},
				{
					"type": "build",
					"name": "release"
				}
			]
		}
	]
}	
